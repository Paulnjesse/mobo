# ── Google Maps (optional) ────────────────────────────────────────────────────
# Without this key the app uses OpenStreetMap (Nominatim + OSRM) as a fallback.
# Required Google Cloud APIs to enable:
#   Maps SDK for Android, Maps SDK for iOS,
#   Places API, Directions API, Geocoding API
#
EXPO_PUBLIC_GOOGLE_MAPS_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Google OAuth (Social Sign-In) ─────────────────────────────────────────────
# Create OAuth credentials at console.cloud.google.com
# Web client ID (used by Expo Auth Proxy in development)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
# iOS client ID (for direct Sign In with Apple on iOS)
GOOGLE_CLIENT_ID_IOS=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
# Android client ID
GOOGLE_CLIENT_ID_ANDROID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# ── Stripe (Card payments) ────────────────────────────────────────────────────
# Get from dashboard.stripe.com → Developers → API keys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Apple Sign-In ─────────────────────────────────────────────────────────────
# Must match the bundle identifier in app.json / app.config.js
# Example: com.yourcompany.mobo
APPLE_APP_BUNDLE_ID=com.yourcompany.mobo
