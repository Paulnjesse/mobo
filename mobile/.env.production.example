# Production environment variables for EAS build
# Copy to .env.production and fill in real values before building.
# NEVER commit .env.production to git.

# ── Backend service URLs ───────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=https://mobo-api-gateway.onrender.com/api/v1
EXPO_PUBLIC_RIDE_SOCKET_URL=https://mobo-ride-service.onrender.com
EXPO_PUBLIC_LOCATION_SOCKET_URL=https://mobo-location-service.onrender.com

# ── Certificate pinning (REQUIRED in production) ──────────────────────────────
# See mobile/src/services/pinnedApi.js for full setup instructions.
# Generate with:
#   openssl s_client -connect mobo-api-gateway.onrender.com:443 </dev/null 2>/dev/null \
#     | openssl x509 -pubkey -noout | openssl pkey -pubin -outform der \
#     | openssl dgst -sha256 -binary | base64
EXPO_PUBLIC_API_CERT_SHA256=REPLACE_WITH_ACTUAL_CERT_HASH
EXPO_PUBLIC_API_CERT_SHA256_BACKUP=REPLACE_WITH_BACKUP_CERT_HASH

# ── Google Maps ────────────────────────────────────────────────────────────────
# Enable: Maps SDK for Android, Maps SDK for iOS, Places API, Directions API,
# Geocoding API at console.cloud.google.com.
# Restrict the key to com.mobo.mobile (Android) and com.mobo.mobile (iOS bundle).
EXPO_PUBLIC_GOOGLE_MAPS_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Google OAuth (Social Sign-In) ─────────────────────────────────────────────
# Create an OAuth 2.0 Web client ID at console.cloud.google.com → APIs & Services.
# This is the web client ID used by the Expo Auth Proxy redirect flow.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# ── Stripe (Card payments) ────────────────────────────────────────────────────
# Use LIVE publishable key (pk_live_...) for production.
# Get from dashboard.stripe.com → Developers → API keys.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Apple Sign-In ─────────────────────────────────────────────────────────────
# Must match the bundle identifier in app.json.
APPLE_APP_BUNDLE_ID=com.mobo.mobile
