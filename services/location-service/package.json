{
  "name": "mobo-location-service",
  "version": "1.0.0",
  "description": "MOBO Location Service - Real-time tracking, nearby drivers, surge zones",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --testEnvironment node --forceExit",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.3.42",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.51.0",
    "@opentelemetry/resources": "^1.24.0",
    "@opentelemetry/sdk-node": "^0.51.0",
    "@opentelemetry/semantic-conventions": "^1.24.0",
    "@sentry/node": "^7.99.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.7.9",
    "compression": "1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "prom-client": "^15.1.0",
    "socket.io": "^4.6.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "forceExit": true,
    "testTimeout": 15000,
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js",
      "!src/tracing.js"
    ],
    "coverageThresholds": {
      "global": {
        "lines": 40,
        "functions": 40,
        "branches": 30,
        "statements": 40
      }
    },
    "coverageReporters": [
      "text",
      "lcov",
      "clover"
    ]
  }
}
