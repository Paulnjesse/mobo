PORT=3003
NODE_ENV=development
DATABASE_URL=postgresql://mobo_user:mobo_pass@localhost:5432/mobo
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxx

# ── Webhook security ──────────────────────────────────────────────────────────
MTN_WEBHOOK_SECRET=change_me_mtn_webhook_secret
ORANGE_WEBHOOK_SECRET=change_me_orange_webhook_secret

# ── Wave (West/Central Africa) ────────────────────────────────────────────────
WAVE_API_KEY=your_wave_api_key_here

# ── MTN Mobile Money (https://momodeveloper.mtn.com/) ───────────────────────
# 1. Register at momodeveloper.mtn.com and subscribe to "Collections" product
# 2. Create a sandbox API user via: POST /v1_0/apiuser  (use UUID v4 as X-Reference-Id)
# 3. Generate API key via:          POST /v1_0/apiuser/{apiUserId}/apikey
MTN_API_USER_ID=your_mtn_api_user_uuid_v4
MTN_API_KEY=your_mtn_api_key
MTN_COLLECTION_SUBSCRIPTION_KEY=your_mtn_collections_subscription_key
MTN_ENVIRONMENT=sandbox
# For production: https://momodeveloper.mtn.com  (change MTN_ENVIRONMENT=mtncameroon)
MTN_BASE_URL=https://sandbox.momodeveloper.mtn.com

# ── Orange Money Cameroon (https://developer.orange.com/) ───────────────────
# 1. Register at developer.orange.com → "Orange Money Web Pay" product for CM
# 2. Create an app → get Client ID and Client Secret
# 3. Get Merchant Key from Orange Money merchant portal
ORANGE_CLIENT_ID=your_orange_client_id
ORANGE_CLIENT_SECRET=your_orange_client_secret
ORANGE_MERCHANT_KEY=your_orange_merchant_key
# Webhook and return URLs (your public API base URL)
API_BASE_URL=https://api.yourdomain.com
ORANGE_RETURN_URL=https://mobo.cm/payment/return
ORANGE_CANCEL_URL=https://mobo.cm/payment/cancel
ORANGE_NOTIF_URL=https://api.yourdomain.com/payments/webhook/orange

# ── Sentry Error Monitoring ───────────────────────────────────────────────────
# Get your DSN from sentry.io → Project → Settings → Client Keys
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ── OpenTelemetry Distributed Tracing ─────────────────────────────────────────
# Set to your Honeycomb/Jaeger/Grafana Tempo OTLP endpoint
# e.g.: https://api.honeycomb.io/v1/traces  or  http://otel-collector:4318/v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Database Read Replica (Supabase Connection Pooler) ─────────────────────────
# Leave empty to use DATABASE_URL for both reads and writes
# In production: use Supabase's connection pooler URL for reads
DATABASE_READ_URL=
