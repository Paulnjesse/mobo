PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://mobo_user:mobo_pass@localhost:5432/mobo
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
JWT_EXPIRES_IN=7d

# ── SMS (Twilio) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# For Gmail: use an App Password (not your account password).
# Go to myaccount.google.com → Security → 2-Step Verification → App Passwords.
#
# For production (recommended): use a transactional email service instead:
#   SendGrid:  smtp.sendgrid.net  port 587  user=apikey  pass=<SendGrid API key>
#   Mailgun:   smtp.mailgun.org   port 587
#   Brevo:     smtp-relay.brevo.com port 587
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
FROM_EMAIL=noreply@mobo.app

# ── Google Sign-In (server-side token verification) ───────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# ── Apple Sign-In (server-side JWT verification) ──────────────────────────────
APPLE_APP_BUNDLE_ID=com.yourcompany.mobo

# ── Smile Identity (KYC / Biometric verification) ─────────────────────────────
# Register at smileidentity.com → Settings → API Keys
# SID_SERVER: 0 = sandbox, 1 = production
SMILE_PARTNER_ID=0000
SMILE_API_KEY=your_smile_api_key_here
SMILE_SID_SERVER=0

# ── Webhook security ──────────────────────────────────────────────────────────
# Shared secret for validating incoming mobile-money webhooks
MTN_WEBHOOK_SECRET=change_me_mtn_webhook_secret
ORANGE_WEBHOOK_SECRET=change_me_orange_webhook_secret

# ── Sentry Error Monitoring ───────────────────────────────────────────────────
# Get your DSN from sentry.io → Project → Settings → Client Keys
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ── OpenTelemetry Distributed Tracing ─────────────────────────────────────────
# Set to your Honeycomb/Jaeger/Grafana Tempo OTLP endpoint
# e.g.: https://api.honeycomb.io/v1/traces  or  http://otel-collector:4318/v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Database Read Replica (Supabase Connection Pooler) ─────────────────────────
# Leave empty to use DATABASE_URL for both reads and writes
# In production: use Supabase's connection pooler URL for reads
DATABASE_READ_URL=
