PORT=3000
NODE_ENV=development
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars_long
USER_SERVICE_URL=http://localhost:3001
RIDE_SERVICE_URL=http://localhost:3002
PAYMENT_SERVICE_URL=http://localhost:3003
LOCATION_SERVICE_URL=http://localhost:3004
CLIENT_URL=http://localhost:3000
# ── CORS (comma-separated allowed origins) ────────────────────────────────────
# In production: set to your actual frontend/app origin(s), e.g. https://moboride.com
CORS_ORIGIN=http://localhost:3000,http://localhost:19006

# ── Sentry Error Monitoring ───────────────────────────────────────────────────
# Get your DSN from sentry.io → Project → Settings → Client Keys
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ── Redis (optional — enables distributed rate limiting across instances) ──────
# Format: redis://[:password@]host[:port][/db]
# If not set, falls back to in-memory rate limiting (single instance only)
REDIS_URL=redis://localhost:6379

# ── OpenTelemetry Distributed Tracing ─────────────────────────────────────────
# Set to your Honeycomb/Jaeger/Grafana Tempo OTLP endpoint
# e.g.: https://api.honeycomb.io/v1/traces  or  http://otel-collector:4318/v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Database Read Replica (Supabase Connection Pooler) ─────────────────────────
# Leave empty to use DATABASE_URL for both reads and writes
# In production: use Supabase's connection pooler URL for reads
DATABASE_READ_URL=

# ── Prometheus scraper IP allowlist ───────────────────────────────────────────
# Comma-separated. Only these IPs may call GET /metrics.
METRICS_ALLOWED_IPS=127.0.0.1,::1,::ffff:127.0.0.1

# ── Internal service auth (shared across all MOBO services) ──────────────────
INTERNAL_SERVICE_KEY=mobo_internal_dev_key_CHANGE_ME
